// SIGA Deportes — modelo de datos.
// Dev y producción: MySQL (Hostinger solo ofrece MySQL en su plan de app Node.js).
// No se usan enums nativos ni Json de Prisma para mantener el modelo simple y portable
// (validados en la capa de aplicación con Zod). Los campos de texto largo/libre llevan
// @db.Text explícito porque MySQL trunca String a VARCHAR(191) por defecto.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// Rol funcional (los 9 roles del catálogo v4)
model Rol {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique
  descripcion String?
  estado      String    @default("Activo")
  usuarios    Usuario[]
  permisos    Permiso[]

  @@map("roles")
}

/// Módulo de la plataforma (MOD-001 … MOD-029)
model Modulo {
  id        Int       @id @default(autoincrement())
  codigo    String    @unique // MOD-001
  nombre    String
  categoria String?
  esBase    Boolean   @default(false)
  estado    String    @default("Activo")
  permisos  Permiso[]

  @@map("modulos")
}

/// Matriz de permisos: rol × módulo → nivel (E | A | L | C | NONE)
model Permiso {
  id       Int    @id @default(autoincrement())
  rolId    Int
  moduloId Int
  nivel    String // E=Escritura A=Aprobación L=Lectura C=Carga NONE=Sin acceso
  rol      Rol    @relation(fields: [rolId], references: [id], onDelete: Cascade)
  modulo   Modulo @relation(fields: [moduloId], references: [id], onDelete: Cascade)

  @@unique([rolId, moduloId])
  @@map("permisos")
}

/// Usuario del sistema (IAM)
model Usuario {
  id                        Int                     @id @default(autoincrement())
  nombre                    String
  correo                    String                  @unique
  passwordHash              String
  rolId                     Int
  estado                    String                  @default("Activo") // Activo | Inactivo | Bloqueado
  ultimoAcceso              DateTime?
  createdAt                 DateTime                @default(now())
  rol                       Rol                     @relation(fields: [rolId], references: [id])
  auditorias                AuditLog[]
  contratosRegistrados      Contrato[]              @relation("registrante")
  contratosAprobados        Contrato[]              @relation("aprobador")
  convocatoriasCreadas      Convocatoria[]          @relation("conv_creador")
  seleccionesPropuestas     SeleccionBeneficiario[] @relation("sel_proponente")
  seleccionesAprobadas      SeleccionBeneficiario[] @relation("sel_aprobador")
  seguimientosCreados       Seguimiento[]           @relation("seg_creador")
  informesCreados           Informe[]               @relation("inf_creador")
  fuentesCreadas            FuenteFinanciacion[]    @relation("fuente_creador")
  fuentesAprobadas          FuenteFinanciacion[]    @relation("fuente_aprobador")
  rubrosCreados             Rubro[]                 @relation("rubro_creador")
  rubrosAprobados           Rubro[]                 @relation("rubro_aprobador")
  cuentasCreadas            CuentaCobro[]           @relation("cuenta_creador")
  cuentasAprobadas          CuentaCobro[]           @relation("cuenta_aprobador")
  pagosRegistrados          Pago[]                  @relation("pago_creador")
  pagosAprobados            Pago[]                  @relation("pago_aprobador")
  polizasCreadas            Poliza[]                @relation("poliza_creador")
  polizasAprobadas          Poliza[]                @relation("poliza_aprobador")
  secopCreados              RegistroSecop[]         @relation("secop_creador")
  secopAprobados            RegistroSecop[]         @relation("secop_aprobador")
  avancesCreados            AvanceMeta[]            @relation("avance_creador")
  avancesAprobados          AvanceMeta[]            @relation("avance_aprobador")
  analisisCreados           AnalisisImpacto[]       @relation("analisis_creador")
  itemsCreados              Item[]                  @relation("item_creador")
  dotacionesCreadas         DotacionEntrega[]       @relation("dotacion_creador")
  lotesCreados              Lote[]                  @relation("lote_creador")
  escenariosCreados         Escenario[]             @relation("escenario_creador")
  reservasCreadas           ReservaEscenario[]      @relation("reserva_creador")
  conflictosGenerados       LogConflicto[]          @relation("conflicto_usuario")
  mantenimientosCreados     Mantenimiento[]         @relation("mant_creador")
  territoriosCreados        Territorio[]            @relation("territorio_creador")
  evaluacionesEsalCreadas   EvaluacionEsal[]        @relation("evalesal_creador")
  evaluacionesEsalAprobadas EvaluacionEsal[]        @relation("evalesal_aprobador")
  evaluacionesPsicCreadas   EvaluacionPsicosocial[] @relation("evalpsico_creador")
  actasCreadas              ActaComite[]            @relation("acta_creador")
  actasAprobadas            ActaComite[]            @relation("acta_aprobador")
  comunicacionesCreadas     Comunicacion[]          @relation("comunicacion_creador")
  notificacionesCreadas     Notificacion[]          @relation("notificacion_creador")
  hallazgosCreados          HallazgoAuditoria[]     @relation("hallazgo_creador")
  accesosEmergencia         AccesoEmergenciaIAM[]   @relation("acceso_emergencia_usuario")
  configCloudActualizada    ConfiguracionCloud[]    @relation("config_cloud_actualizador")
  personalCreado            Personal[]              @relation("personal_creador")
  personalAprobado          Personal[]              @relation("personal_aprobador")
  dotacionesDevueltas       DotacionEntrega[]       @relation("dotacion_devuelto")
  documentosCreados         Documento[]             @relation("documento_creador")

  @@map("usuarios")
}

/// Bitácora de auditoría (RN-014: toda acción crítica queda registrada)
model AuditLog {
  id            Int      @id @default(autoincrement())
  usuarioId     Int?
  accion        String // crear | editar | baja | login
  modulo        String // MOD-001
  registroId    String?
  valorAnterior String?  @db.Text // JSON serializado
  valorNuevo    String?  @db.Text // JSON serializado
  ip            String?
  fechaHora     DateTime @default(now())
  usuario       Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([modulo, accion, fechaHora])
  @@map("auditoria")
}

/// MOD-001 Beneficiarios
model Beneficiario {
  id           Int      @id @default(autoincrement())
  documento    String   @unique
  nombre       String
  edad         Int?
  sexo         String? // M | F | Otro
  programa     String?
  territorioId Int?
  estado       String   @default("Activo") // Activo | Inactivo (RN-002: baja lógica, nunca DELETE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Identidad (ficha de inscripción)
  primerNombre       String?
  segundoNombre      String?
  primerApellido     String?
  segundoApellido    String?
  genero             String? // ficha: Femenino | Masculino | Otro — distinto de `sexo` (dominio legado, no se fusiona)
  tipoDocumento      String? // TI | CC | RC | CE | PEP
  fechaExpedicionDoc DateTime?
  lugarExpedicionDoc String?
  lugarNacimiento    String?
  fechaNacimiento    DateTime?

  // Datos físicos
  estaturaCm Int?
  pesoKg     Float?
  tipoSangre String?
  talla      String?

  // Ubicación / domicilio (del beneficiario, distinto de Territorio)
  direccionDomicilio  String? @db.Text
  ubicacionDomicilio  String? // Urbano | Rural
  estrato             Int?
  veredaCorregimiento String?
  nombreSede          String?
  jornada             String? // Mañana | Única | Tarde

  // Educación
  grado                   String?
  descolarizado           Boolean @default(false)
  institucionEducativa    String?
  secretariaEducacionCert String?
  nombreEstablecimiento   String?
  nombreSedeEducativa     String?
  codigoDaneSede          String?
  codigoDaneMunicipio     String?

  // Salud / afiliación
  afiliacionSalud     String? // Subsidiado | Contributivo | Otro
  otroTipoAfiliacion  String?
  eps                 String?
  consumeMedicamento  Boolean @default(false)
  cualMedicamento     String? @db.Text
  correoElectronico   String?
  tieneConvulsiones   Boolean @default(false)
  tieneCardiovascular Boolean @default(false)
  tieneRespiratoria   Boolean @default(false)
  tieneAlergias       Boolean @default(false)
  tieneEpilepsia      Boolean @default(false)
  tieneOtraEnfermedad Boolean @default(false)
  cualOtraEnfermedad  String? @db.Text

  // Discapacidad
  diagnosticadoDiscapacidad Boolean @default(false)
  tieneRegistroLocalizacion Boolean @default(false)
  discapacidadFisicoMotor   Boolean @default(false)
  discapacidadVisual        Boolean @default(false)
  discapacidadAuditiva      Boolean @default(false)
  discapacidadIntelectual   Boolean @default(false)
  discapacidadMultiple      Boolean @default(false)
  cualDiscapacidad          String? @db.Text
  recomendacionMedica       String? @db.Text

  // Población especial
  tipoPoblacion             String? // Ninguno|Afro|Campesino|Indígena|Otro|Raizal|Víctima del conflicto|ROM|Hijo de mujer lideresa
  cabildoResguardo          String?
  otroTipoCondicionEspecial Boolean @default(false)
  cualOtraCondicion         String? @db.Text
  victimaConflictoArmado    Boolean @default(false)
  registroUnicoVictimas     Boolean @default(false)
  numeroRuv                 String?

  // Documentos anexos (checklist fija)
  docRegistroCivilOTi           Boolean @default(false)
  docCertificadoEpsAdres        Boolean @default(false)
  docCedulaAcudiente            Boolean @default(false)
  docConsentimientoAsentimiento Boolean @default(false)
  docFichaInscripcion           Boolean @default(false)
  docAceptoPoliticaDatos        Boolean @default(false)

  // Alimentación
  cuentaConAlimentacion      Boolean @default(false)
  tipoComplementoAlimentario String?
  modalidadAlimentacion      String?
  requiereAlimentacionCentro Boolean @default(false)

  // Transporte
  medioTransporte          String?
  tiempoRecorrido          String?
  requiereTransporteCentro Boolean @default(false)
  requerimientoTransporte  String? @db.Text

  // Meta / registro (formador / grupo)
  nombreFormador           String?
  ccFormador               String?
  tipoPoblacionFormador    String?
  grupoCentroInteres       String?
  observacionesRegistro    String?   @db.Text
  fechaIngreso             DateTime?
  departamentoBeneficiario String? // dato propio de la ficha — NO confundir con Territorio.departamento

  territorio                Territorio?             @relation(fields: [territorioId], references: [id])
  selecciones               SeleccionBeneficiario[]
  seguimientos              Seguimiento[]
  dotaciones                DotacionEntrega[]
  evaluacionesPsicosociales EvaluacionPsicosocial[]
  acudiente                 Acudiente?
  contactoEmergencia        ContactoEmergencia?

  @@index([estado, nombre])
  @@map("beneficiarios")
}

/// MOD-001 — acudiente del beneficiario. 1 beneficiario tiene a lo sumo 1 acudiente (FK única).
model Acudiente {
  id             Int          @id @default(autoincrement())
  beneficiarioId Int          @unique
  nombres        String
  edad           Int?
  documento      String?
  parentesco     String?
  direccion      String?      @db.Text
  telefono       String?
  correo         String?
  ocupacion      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  beneficiario   Beneficiario @relation(fields: [beneficiarioId], references: [id], onDelete: Cascade)

  @@map("acudientes")
}

/// MOD-001 — contacto de emergencia del beneficiario (persona distinta del acudiente).
model ContactoEmergencia {
  id             Int          @id @default(autoincrement())
  beneficiarioId Int          @unique
  nombres        String
  parentesco     String?
  direccion      String?      @db.Text
  telefono       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  beneficiario   Beneficiario @relation(fields: [beneficiarioId], references: [id], onDelete: Cascade)

  @@map("contactos_emergencia")
}

/// MOD-004 Inventarios — bienes y equipos
model Item {
  id          Int               @id @default(autoincrement())
  codigo      String            @unique
  nombre      String
  categoria   String?
  ubicacion   String?
  cantidad    Int               @default(0)
  estado      String            @default("Activo")
  createdById Int?
  createdAt   DateTime          @default(now())
  createdBy   Usuario?          @relation("item_creador", fields: [createdById], references: [id])
  dotaciones  DotacionEntrega[]

  @@index([estado])
  @@map("items")
}

/// MOD-013 Dotación deportiva — entrega de ítems a beneficiarios
model DotacionEntrega {
  id              Int          @id @default(autoincrement())
  beneficiarioId  Int
  itemId          Int
  cantidad        Int          @default(1)
  fechaEntrega    DateTime     @default(now())
  fechaDevolucion DateTime?
  estado          String       @default("Entregada") // Entregada | Devuelta
  createdById     Int?
  devueltoById    Int?
  createdAt       DateTime     @default(now())
  beneficiario    Beneficiario @relation(fields: [beneficiarioId], references: [id])
  item            Item         @relation(fields: [itemId], references: [id])
  createdBy       Usuario?     @relation("dotacion_creador", fields: [createdById], references: [id])
  devueltoBy      Usuario?     @relation("dotacion_devuelto", fields: [devueltoById], references: [id])

  @@index([estado])
  @@map("dotacion_entregas")
}

/// MOD-017 Gestión de lotes — predios/terrenos
model Lote {
  id           Int         @id @default(autoincrement())
  codigo       String      @unique
  direccion    String?     @db.Text
  area         Float?
  territorioId Int?
  estado       String      @default("Activo")
  createdById  Int?
  createdAt    DateTime    @default(now())
  territorio   Territorio? @relation(fields: [territorioId], references: [id])
  createdBy    Usuario?    @relation("lote_creador", fields: [createdById], references: [id])
  escenarios   Escenario[]

  @@index([estado])
  @@map("lotes")
}

/// Catálogo de escenarios deportivos (gestionado dentro de MOD-022 Reservas)
model Escenario {
  id             Int                @id @default(autoincrement())
  nombre         String
  tipo           String? // Cancha | Coliseo | Piscina | Pista
  direccion      String?            @db.Text
  capacidad      Int?
  estado         String             @default("Activo")
  lat            Float? // MOD-024 Georeferenciación
  lng            Float?
  loteId         Int? // predio sobre el que se construyó (MOD-017)
  territorioId   Int? // caracterización territorial (MOD-012)
  createdById    Int?
  createdAt      DateTime           @default(now())
  lote           Lote?              @relation(fields: [loteId], references: [id])
  territorio     Territorio?        @relation(fields: [territorioId], references: [id])
  createdBy      Usuario?           @relation("escenario_creador", fields: [createdById], references: [id])
  reservas       ReservaEscenario[]
  mantenimientos Mantenimiento[]

  @@map("escenarios")
}

/// MOD-012 Caracterización territorial — también alimenta MOD-024 Georeferenciación (lat/lng)
model Territorio {
  id            Int            @id @default(autoincrement())
  codigo        String         @unique
  municipio     String
  departamento  String
  zona          String?
  poblacion     Int?
  lat           Float?
  lng           Float?
  estado        String         @default("Activo")
  createdById   Int?
  createdAt     DateTime       @default(now())
  createdBy     Usuario?       @relation("territorio_creador", fields: [createdById], references: [id])
  beneficiarios Beneficiario[]
  lotes         Lote[]
  escenarios    Escenario[]
  contratos     Contrato[]

  @@index([estado])
  @@index([municipio])
  @@index([zona])
  @@map("territorios")
}

/// MOD-009 Evaluación ESAL — RN-025-style SoD: Administrador registra (E), Supervisor aprueba (A)
model EvaluacionEsal {
  id             Int           @id @default(autoincrement())
  terceroId      Int
  convocatoriaId Int?
  criterio       String?       @db.Text
  puntaje        Float?
  estado         String        @default("Registrada") // Registrada | Aprobada | Rechazada
  motivoRechazo  String?       @db.Text
  createdById    Int?
  aprobadoById   Int?
  aprobadoEn     DateTime?
  createdAt      DateTime      @default(now())
  tercero        Tercero       @relation(fields: [terceroId], references: [id])
  convocatoria   Convocatoria? @relation(fields: [convocatoriaId], references: [id])
  createdBy      Usuario?      @relation("evalesal_creador", fields: [createdById], references: [id])
  aprobadoBy     Usuario?      @relation("evalesal_aprobador", fields: [aprobadoById], references: [id])

  @@map("evaluaciones_esal")
}

/// MOD-018 Eval. psicosocial — sin nivel A en la matriz (varios roles con E)
model EvaluacionPsicosocial {
  id             Int          @id @default(autoincrement())
  beneficiarioId Int
  fecha          DateTime?
  instrumento    String?
  resultado      String?      @db.Text
  nivelRiesgo    String? // Bajo | Medio | Alto — dispara alerta cuando es Alto
  estado         String       @default("Registrada") // Registrada | Revisada
  observacion    String?      @db.Text
  createdById    Int?
  createdAt      DateTime     @default(now())
  beneficiario   Beneficiario @relation(fields: [beneficiarioId], references: [id])
  createdBy      Usuario?     @relation("evalpsico_creador", fields: [createdById], references: [id])

  @@map("evaluaciones_psicosociales")
}

/// MOD-022 Reservas escenario — RN-024 (anti-solapamiento + margen 30 min) y RN-024-B (override de emergencia, solo Administrador)
model ReservaEscenario {
  id               Int       @id @default(autoincrement())
  escenarioId      Int
  tipoUso          String?
  fechaInicio      DateTime
  fechaFin         DateTime
  estado           String    @default("Activa") // Activa | Cancelada | Emergencia
  periodo          String?
  esEmergencia     Boolean   @default(false)
  motivoEmergencia String?   @db.Text
  createdById      Int?
  createdAt        DateTime  @default(now())
  escenario        Escenario @relation(fields: [escenarioId], references: [id])
  createdBy        Usuario?  @relation("reserva_creador", fields: [createdById], references: [id])

  @@index([escenarioId, estado])
  @@map("reservas_escenario")
}

/// DEP-031 — log de conflictos de reservas (rechazos por solapamiento y overrides de emergencia)
model LogConflicto {
  id                 Int       @id @default(autoincrement())
  escenarioId        Int
  reservaExistenteId Int?
  tipo               String // Solapamiento | Override
  fechaIntentoInicio DateTime?
  fechaIntentoFin    DateTime?
  motivo             String?   @db.Text
  usuarioId          Int?
  createdAt          DateTime  @default(now())
  usuario            Usuario?  @relation("conflicto_usuario", fields: [usuarioId], references: [id])

  @@map("log_conflictos")
}

/// MOD-023 Mantenimiento de escenarios — alimenta KPI-029b (mantenimientos a tiempo)
model Mantenimiento {
  id             Int       @id @default(autoincrement())
  escenarioId    Int
  tipo           String    @default("Programado") // Programado | Correctivo | Emergencia
  descripcion    String?   @db.Text
  fechaInicio    DateTime?
  fechaFin       DateTime?
  cerradoATiempo Boolean?
  costo          Float     @default(0)
  estado         String    @default("Programado") // Programado | En curso | Cerrado
  createdById    Int?
  createdAt      DateTime  @default(now())
  escenario      Escenario @relation(fields: [escenarioId], references: [id])
  createdBy      Usuario?  @relation("mant_creador", fields: [createdById], references: [id])

  @@index([escenarioId, estado])
  @@map("mantenimientos")
}

/// Tercero contratado (ESAL / operador / persona)
model Tercero {
  id               Int              @id @default(autoincrement())
  documento        String           @unique
  razonSocial      String
  tipo             String           @default("ESAL") // ESAL | Persona natural | Empresa
  estado           String           @default("Activo")
  contratos        Contrato[]
  evaluacionesEsal EvaluacionEsal[]

  @@map("terceros")
}

/// MOD-010 Contratos — flujo RN-025 (doble aprobación: Financiera registra, Administrador aprueba)
model Contrato {
  id             Int            @id @default(autoincrement())
  numero         String         @unique
  objeto         String         @db.Text
  terceroId      Int
  convocatoriaId Int? // MOD-008: contrato derivado de una convocatoria adjudicada
  territorioId   Int? // municipio donde se ejecuta — alimenta el mapa de calor de inversión
  valorTotal     Float          @default(0)
  fechaInicio    DateTime?
  fechaFin       DateTime?
  supervisor     String?
  estado         String         @default("Registrado") // Registrado | Aprobado | Rechazado | Cerrado
  motivoRechazo  String?        @db.Text
  createdById    Int?
  aprobadoById   Int?
  aprobadoEn     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  tercero        Tercero        @relation(fields: [terceroId], references: [id])
  convocatoria   Convocatoria?  @relation(fields: [convocatoriaId], references: [id])
  territorio     Territorio?    @relation(fields: [territorioId], references: [id])
  createdBy      Usuario?       @relation("registrante", fields: [createdById], references: [id])
  aprobadoBy     Usuario?       @relation("aprobador", fields: [aprobadoById], references: [id])
  informes       Informe[]
  documentos     Documento[]
  cuentasCobro   CuentaCobro[]
  polizas        Poliza[]
  registroSecop  RegistroSecop?
  actasComite    ActaComite[]

  @@index([estado, createdAt])
  @@map("contratos")
}

/// MOD-016 Indicadores físicos — metas programadas. Sin nivel A en la matriz (varios roles con E);
/// la aprobación del avance usa el mismo nivel E (sin SoD de doble control aquí).
model IndicadorFisico {
  id         Int          @id @default(autoincrement())
  codigo     String       @unique
  nombre     String
  unidad     String? // cupos | sesiones | beneficiarios | eventos
  programado Float        @default(0)
  periodo    String
  estado     String       @default("Activo")
  createdAt  DateTime     @default(now())
  avances    AvanceMeta[]

  @@index([estado])
  @@map("indicadores_fisicos")
}

/// Avance reportado sobre un indicador — RN-011: solo lo Aprobado suma al cumplimiento.
model AvanceMeta {
  id                Int             @id @default(autoincrement())
  indicadorId       Int
  cantidadReportada Float
  cantidadAprobada  Float?
  estado            String          @default("Reportado") // Reportado | Aprobado | Rechazado
  periodo           String?
  motivoRechazo     String?         @db.Text
  createdById       Int?
  aprobadoById      Int?
  aprobadoEn        DateTime?
  createdAt         DateTime        @default(now())
  indicador         IndicadorFisico @relation(fields: [indicadorId], references: [id])
  createdBy         Usuario?        @relation("avance_creador", fields: [createdById], references: [id])
  aprobadoBy        Usuario?        @relation("avance_aprobador", fields: [aprobadoById], references: [id])

  @@index([indicadorId, estado])
  @@map("avances_meta")
}

/// MOD-025 Análisis de impacto — RN-021: alerta de desviación gasto financiero vs cumplimiento físico.
model AnalisisImpacto {
  id                  Int      @id @default(autoincrement())
  periodo             String
  gastoEjecutado      Float    @default(0)
  cumplimientoFisico  Float    @default(0) // % 0-100
  ejecucionFinanciera Float    @default(0) // % 0-100
  desviacion          Float    @default(0) // ejecucionFinanciera - cumplimientoFisico
  createdById         Int?
  createdAt           DateTime @default(now())
  createdBy           Usuario? @relation("analisis_creador", fields: [createdById], references: [id])

  @@map("analisis_impacto")
}

/// MOD-020 Fuentes de financiación — RN-025: Financiera registra (E), Administrador aprueba (A)
model FuenteFinanciacion {
  id              Int       @id @default(autoincrement())
  codigo          String    @unique
  nombre          String
  tipo            String? // Nación | Departamento | Municipio | Cooperación | Propios
  valorDisponible Float     @default(0)
  vigencia        String?
  estado          String    @default("Registrada") // Registrada | Aprobada | Rechazada
  motivoRechazo   String?   @db.Text
  createdById     Int?
  aprobadoById    Int?
  aprobadoEn      DateTime?
  createdAt       DateTime  @default(now())
  createdBy       Usuario?  @relation("fuente_creador", fields: [createdById], references: [id])
  aprobadoBy      Usuario?  @relation("fuente_aprobador", fields: [aprobadoById], references: [id])
  rubros          Rubro[]

  @@map("fuentes_financiacion")
}

/// Rubro presupuestal — agrupado bajo una fuente. RN-025: Financiera propone la meta de inversión
/// (valorAsignado), Administrador la aprueba. Solo rubros Aprobados pueden recibir cuentas de cobro.
model Rubro {
  id            Int                @id @default(autoincrement())
  codigo        String             @unique
  nombre        String
  fuenteId      Int
  valorAsignado Float              @default(0) // meta de inversión del rubro
  vigencia      String?
  estado        String             @default("Registrado") // Registrado | Aprobado | Rechazado
  motivoRechazo String?            @db.Text
  createdById   Int?
  aprobadoById  Int?
  aprobadoEn    DateTime?
  createdAt     DateTime           @default(now())
  fuente        FuenteFinanciacion @relation(fields: [fuenteId], references: [id])
  createdBy     Usuario?           @relation("rubro_creador", fields: [createdById], references: [id])
  aprobadoBy    Usuario?           @relation("rubro_aprobador", fields: [aprobadoById], references: [id])
  cuentas       CuentaCobro[]

  @@index([fuenteId])
  @@index([estado])
  @@map("rubros")
}

/// MOD-003 Financiera — cuenta de cobro: RN-005 (contrato activo), RN-006 (informe aprobado),
/// RN-007 (imputada a rubro), RN-018 (bloqueo por póliza vencida). RN-025: Financiera registra, Administrador aprueba.
model CuentaCobro {
  id            Int       @id @default(autoincrement())
  contratoId    Int
  informeId     Int?
  rubroId       Int
  periodo       String
  valorCobrado  Float     @default(0)
  valorAprobado Float?
  estado        String    @default("Registrada") // Registrada | Aprobada | Rechazada | Pagada
  motivoRechazo String?   @db.Text
  createdById   Int?
  aprobadoById  Int?
  aprobadoEn    DateTime?
  createdAt     DateTime  @default(now())
  contrato      Contrato  @relation(fields: [contratoId], references: [id])
  rubro         Rubro     @relation(fields: [rubroId], references: [id])
  createdBy     Usuario?  @relation("cuenta_creador", fields: [createdById], references: [id])
  aprobadoBy    Usuario?  @relation("cuenta_aprobador", fields: [aprobadoById], references: [id])
  pagos         Pago[]

  @@index([rubroId, estado])
  @@map("cuentas_cobro")
}

/// Pago contra una cuenta de cobro aprobada — RN-008 (≤ valor aprobado), RN-009 (≤ saldo de rubro), RN-023 (no negativo)
/// Orden de pago contra una cuenta de cobro aprobada — RN-025: Financiera ordena (E), Administrador
/// aprueba (A). No es una transacción en línea: el sistema registra la orden/aprobación administrativa;
/// la ejecución bancaria real (DOC-037 comprobante de egreso) ocurre fuera del sistema, en Tesorería.
model Pago {
  id            Int         @id @default(autoincrement())
  cuentaCobroId Int
  valorPagado   Float
  fechaPago     DateTime    @default(now())
  comprobante   String?
  medioPago     String? // Orden bancaria | Cheque | Giro
  estado        String      @default("Ordenado") // Ordenado | Aprobado | Rechazado
  motivoRechazo String?     @db.Text
  createdById   Int?
  aprobadoById  Int?
  aprobadoEn    DateTime?
  createdAt     DateTime    @default(now())
  cuentaCobro   CuentaCobro @relation(fields: [cuentaCobroId], references: [id])
  createdBy     Usuario?    @relation("pago_creador", fields: [createdById], references: [id])
  aprobadoBy    Usuario?    @relation("pago_aprobador", fields: [aprobadoById], references: [id])

  @@index([estado])
  @@map("pagos")
}

/// MOD-014 Control de pólizas — RN-018 (vigente para aprobar cuentas). RN-025: Financiera registra, Administrador aprueba.
model Poliza {
  id            Int       @id @default(autoincrement())
  contratoId    Int
  tipo          String? // Cumplimiento | Responsabilidad civil | Calidad
  aseguradora   String?
  valor         Float     @default(0)
  vigenciaDesde DateTime?
  vigenciaHasta DateTime?
  estado        String    @default("Registrada") // Registrada | Aprobada | Rechazada
  motivoRechazo String?   @db.Text
  createdById   Int?
  aprobadoById  Int?
  aprobadoEn    DateTime?
  createdAt     DateTime  @default(now())
  contrato      Contrato  @relation(fields: [contratoId], references: [id])
  createdBy     Usuario?  @relation("poliza_creador", fields: [createdById], references: [id])
  aprobadoBy    Usuario?  @relation("poliza_aprobador", fields: [aprobadoById], references: [id])

  @@map("polizas")
}

/// MOD-027 Integración SECOP II — RN-025: Financiera registra, Administrador aprueba.
model RegistroSecop {
  id            Int       @id @default(autoincrement())
  contratoId    Int       @unique // deduplicación: a lo sumo un registro SECOP por contrato
  procesoSecop  String
  estadoSync    String    @default("Registrado") // Registrado | Aprobado | Rechazado | Sincronizado
  motivoRechazo String?   @db.Text
  createdById   Int?
  aprobadoById  Int?
  aprobadoEn    DateTime?
  createdAt     DateTime  @default(now())
  contrato      Contrato  @relation(fields: [contratoId], references: [id])
  createdBy     Usuario?  @relation("secop_creador", fields: [createdById], references: [id])
  aprobadoBy    Usuario?  @relation("secop_aprobador", fields: [aprobadoById], references: [id])

  @@map("registros_secop")
}

/// MOD-002 Personal — hoja de vida y vinculación. RN-025: quien registra (E) no puede aprobar
/// su propia hoja de vida; Supervisor aprueba (A) por matriz. `estado` es la baja lógica (RN-002,
/// independiente de `estadoAprobacion`, que es el flujo de doble control sobre la vinculación).
model Personal {
  id               Int       @id @default(autoincrement())
  documento        String    @unique
  nombre           String
  cargo            String?
  perfil           String?
  tipoVinculacion  String? // Planta | Contratista | OPS
  fechaIngreso     DateTime?
  correo           String?
  telefono         String?
  estado           String    @default("Activo") // Activo | Inactivo — RN-002 baja lógica
  estadoAprobacion String    @default("Pendiente") // Pendiente | Aprobado | Rechazado
  motivoRechazo    String?   @db.Text
  createdById      Int?
  aprobadoById     Int?
  aprobadoEn       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  createdBy        Usuario?  @relation("personal_creador", fields: [createdById], references: [id])
  aprobadoBy       Usuario?  @relation("personal_aprobador", fields: [aprobadoById], references: [id])

  @@index([estado])
  @@map("personal")
}

/// MOD-011 Seguimiento — actividades por beneficiario/programa
model Seguimiento {
  id             Int          @id @default(autoincrement())
  beneficiarioId Int
  programa       String?
  fecha          DateTime?
  actividad      String       @db.Text
  observacion    String?      @db.Text
  estado         String       @default("Registrado")
  createdById    Int?
  createdAt      DateTime     @default(now())
  beneficiario   Beneficiario @relation(fields: [beneficiarioId], references: [id])
  createdBy      Usuario?     @relation("seg_creador", fields: [createdById], references: [id])

  @@index([beneficiarioId])
  @@index([estado])
  @@map("seguimientos")
}

/// MOD-006 Informes — informes de ejecución por contrato/periodo
model Informe {
  id                  Int       @id @default(autoincrement())
  contratoId          Int
  periodo             String // p. ej. 2026-01
  fechaRadicacion     DateTime?
  estado              String    @default("Radicado") // Radicado | Aprobado | Devuelto | Con observaciones
  observacion         String?   @db.Text
  periodoCerrado      Boolean   @default(false) // RN-022
  certificadoGenerado Boolean   @default(false) // RN-023/RN-026
  createdById         Int?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  contrato            Contrato  @relation(fields: [contratoId], references: [id])
  createdBy           Usuario?  @relation("inf_creador", fields: [createdById], references: [id])

  @@index([contratoId, periodo])
  @@index([estado])
  @@map("informes")
}

/// MOD-005 Documental — expediente documental por contrato (con versionado). RN-025: quien
/// carga el documento (createdById) no puede revisarlo/aprobarlo — ver revisarDocumento().
model Documento {
  id            Int                @id @default(autoincrement())
  contratoId    Int
  tipoDocumento String
  obligatorio   Boolean            @default(false)
  estado        String             @default("Pendiente") // Pendiente | Cargado | En revisión | Aprobado | Rechazado | Con observaciones
  archivoUrl    String?            @db.Text
  observacion   String?            @db.Text
  createdById   Int?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  contrato      Contrato           @relation(fields: [contratoId], references: [id])
  createdBy     Usuario?           @relation("documento_creador", fields: [createdById], references: [id])
  versiones     VersionDocumento[]

  @@index([contratoId])
  @@index([estado])
  @@map("documentos")
}

/// Versiones de un documento — RN-012: nunca se sobrescribe la evidencia histórica
model VersionDocumento {
  id           Int       @id @default(autoincrement())
  documentoId  Int
  archivoUrl   String?   @db.Text
  version      Int       @default(1)
  usuarioCarga String?
  nota         String?   @db.Text
  createdAt    DateTime  @default(now())
  documento    Documento @relation(fields: [documentoId], references: [id], onDelete: Cascade)

  @@map("versiones_documento")
}

/// MOD-008 Convocatorias — RN-027: Supervisor selecciona (E), Administrador aprueba (A)
model Convocatoria {
  id               Int                     @id @default(autoincrement())
  nombre           String
  tipo             String                  @default("Beneficiarios")
  descripcion      String?                 @db.Text
  cupos            Int                     @default(0)
  fechaApertura    DateTime?
  fechaCierre      DateTime?
  estado           String                  @default("Abierta") // Borrador | Abierta | En selección | Adjudicada | Cerrada
  createdById      Int?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  createdBy        Usuario?                @relation("conv_creador", fields: [createdById], references: [id])
  selecciones      SeleccionBeneficiario[]
  evaluacionesEsal EvaluacionEsal[]
  contratos        Contrato[]
  actasComite      ActaComite[]
  comunicaciones   Comunicacion[]

  @@map("convocatorias")
}

/// Selección de beneficiarios en una convocatoria (propone Supervisor, aprueba Administrador)
model SeleccionBeneficiario {
  id             Int          @id @default(autoincrement())
  convocatoriaId Int
  beneficiarioId Int
  estado         String       @default("Propuesto") // Propuesto | Aprobado | Rechazado
  propuestoById  Int?
  aprobadoById   Int?
  createdAt      DateTime     @default(now())
  convocatoria   Convocatoria @relation(fields: [convocatoriaId], references: [id], onDelete: Cascade)
  beneficiario   Beneficiario @relation(fields: [beneficiarioId], references: [id])
  propuestoBy    Usuario?     @relation("sel_proponente", fields: [propuestoById], references: [id])
  aprobadoBy     Usuario?     @relation("sel_aprobador", fields: [aprobadoById], references: [id])

  @@unique([convocatoriaId, beneficiarioId])
  @@map("selecciones_beneficiario")
}

/// MOD-015 Comité de control — Supervisor o Coord. deportiva registran (E), Administrador aprueba (A)
model ActaComite {
  id             Int           @id @default(autoincrement())
  fecha          DateTime      @default(now())
  tema           String
  decision       String?       @db.Text
  contratoId     Int? // acta referida a un contrato específico (opcional)
  convocatoriaId Int? // acta referida a una convocatoria específica (opcional)
  estado         String        @default("Registrada") // Registrada | Aprobada | Rechazada
  motivoRechazo  String?       @db.Text
  createdById    Int?
  aprobadoById   Int?
  aprobadoEn     DateTime?
  createdAt      DateTime      @default(now())
  contrato       Contrato?     @relation(fields: [contratoId], references: [id])
  convocatoria   Convocatoria? @relation(fields: [convocatoriaId], references: [id])
  createdBy      Usuario?      @relation("acta_creador", fields: [createdById], references: [id])
  aprobadoBy     Usuario?      @relation("acta_aprobador", fields: [aprobadoById], references: [id])

  @@index([estado])
  @@map("actas_comite")
}

/// MOD-019 Comunicaciones — sin nivel A
model Comunicacion {
  id             Int           @id @default(autoincrement())
  tipo           String        @default("Interna") // Interna | Externa | Prensa
  canal          String? // Correo | WhatsApp | Boletín | Redes
  asunto         String
  contenido      String?       @db.Text
  publico        String? // a quién va dirigida
  convocatoriaId Int? // comunicado derivado de una convocatoria (p. ej. resultados)
  estado         String        @default("Borrador") // Borrador | Enviada
  createdById    Int?
  createdAt      DateTime      @default(now())
  convocatoria   Convocatoria? @relation(fields: [convocatoriaId], references: [id])
  createdBy      Usuario?      @relation("comunicacion_creador", fields: [createdById], references: [id])

  @@index([estado])
  @@map("comunicaciones")
}

/// MOD-021 Notificaciones — cola/registro de avisos del sistema
model Notificacion {
  id           Int      @id @default(autoincrement())
  tipoEvento   String // RN-024-B | RN-026 | RN-025 | Manual
  canal        String   @default("Sistema") // Sistema | Correo | SMS
  destinatario String?
  mensaje      String   @db.Text
  estadoEnvio  String   @default("Pendiente") // Pendiente | Enviada | Fallida
  createdById  Int?
  createdAt    DateTime @default(now())
  createdBy    Usuario? @relation("notificacion_creador", fields: [createdById], references: [id])

  @@index([createdAt])
  @@map("notificaciones")
}

/// MOD-026 Auditoría interna — hallazgos registrados (Supervisor/Revisor=E) sobre el log de auditoría automático
model HallazgoAuditoria {
  id          Int      @id @default(autoincrement())
  modulo      String?
  descripcion String   @db.Text
  gravedad    String   @default("Media") // Baja | Media | Alta
  estado      String   @default("Abierto") // Abierto | Cerrado
  createdById Int?
  createdAt   DateTime @default(now())
  createdBy   Usuario? @relation("hallazgo_creador", fields: [createdById], references: [id])

  @@map("hallazgos_auditoria")
}

/// MOD-028 Seguridad/IAM — RN-026: acceso de emergencia (break-glass), solo rol Administrador
model AccesoEmergenciaIAM {
  id        Int      @id @default(autoincrement())
  usuarioId Int?
  motivo    String   @db.Text
  createdAt DateTime @default(now())
  usuario   Usuario? @relation("acceso_emergencia_usuario", fields: [usuarioId], references: [id])

  @@map("accesos_emergencia_iam")
}

/// MOD-029 Infraestructura cloud — parámetros de estado/configuración
model ConfiguracionCloud {
  id              Int      @id @default(autoincrement())
  clave           String   @unique
  valor           String   @db.Text
  descripcion     String?  @db.Text
  actualizadoById Int?
  updatedAt       DateTime @updatedAt
  actualizadoBy   Usuario? @relation("config_cloud_actualizador", fields: [actualizadoById], references: [id])

  @@map("configuracion_cloud")
}

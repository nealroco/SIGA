# Copia este archivo a .env.test y ajusta los valores si tu instalación local difiere.
#
# Entorno de TEST — NUNCA apuntar esto a la base de datos de dev/producción.
# El nombre del schema DEBE terminar en "_test": el globalSetup de Vitest lo valida
# explícitamente antes de correr "prisma db push --force-reset" (que borra todo el schema).
#
# Mismo servidor MySQL local de dev (127.0.0.1:3307, sin Docker), mismo usuario "siga",
# pero schema separado "siga_deportes_test" (creado una vez con:
#   mysql -u root -e "CREATE DATABASE siga_deportes_test; GRANT ALL PRIVILEGES ON siga_deportes_test.* TO 'siga'@'localhost';"
# ).
DATABASE_URL="mysql://siga:siga2026dev@127.0.0.1:3307/siga_deportes_test"

# Auth.js / NextAuth v5 — src/lib/env.ts exige esta var incluso en test porque
# src/auth.ts la importa ("@/lib/env") en cuanto se importa cualquier Server Action
# que a su vez importe "@/auth". Valor de ejemplo, no es secreto real.
AUTH_SECRET="siga-deportes-test-secret-0123456789"
AUTH_TRUST_HOST=true

NEXT_PUBLIC_SHOW_DEMO_HINT=true

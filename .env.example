# Copia este archivo a .env y ajusta los valores.

# Dev (SQLite, local, sin infraestructura):
DATABASE_URL="file:./dev.db"
# Producción (PostgreSQL): cambiar el provider en prisma/schema.prisma a "postgresql"
# DATABASE_URL="postgresql://usuario:password@host:5432/siga?schema=public"

# Auth.js / NextAuth v5 — genera uno con: npx auth secret
AUTH_SECRET="genera-un-secreto-seguro"
AUTH_TRUST_HOST=true

# Copia este archivo a .env y ajusta los valores.

# MySQL (dev y producción usan el mismo motor — Hostinger solo ofrece MySQL para apps Node.js).
# Dev local: instala MySQL sin instalador (tar.gz oficial, sin sudo) en ~/mysql-siga, puerto 3307.
DATABASE_URL="mysql://siga:siga2026dev@127.0.0.1:3307/siga_deportes"
# Producción (Hostinger): usa la cadena que te da el panel de la app Node.js. Agrega
# ?connection_limit=5&pool_timeout=10 (ajusta el límite al plan MySQL de Hostinger) para
# no agotar las conexiones concurrentes que permite el plan.
# DATABASE_URL="mysql://usuario:password@host:3306/nombre_bd?connection_limit=5&pool_timeout=10"

# Auth.js / NextAuth v5 — genera uno con: npx auth secret
AUTH_SECRET="genera-un-secreto-seguro"
AUTH_TRUST_HOST=true

# Muestra el hint de usuarios demo y precarga nada en el login — SOLO para dev/demo.
# Poner en false (o quitar la variable) en producción.
NEXT_PUBLIC_SHOW_DEMO_HINT=true
